{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": "standard-with-typescript",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "@typescript-eslint/semi": 0,
    "@typescript-eslint/comma-dangle": 0,
    "@typescript-eslint/member-delimiter-style": 0
  }
}
